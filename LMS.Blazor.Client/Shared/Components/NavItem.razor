<div class="nav-item px-2">
    <NavLink class="nav-link px-3 fs-6" 
            href="@Href" Match="NavLinkMatch.All">
        <i class="bi @Icon"></i>
        <span class="ms-2">@Text</span>
    </NavLink>
</div>

@code {
    [Parameter] public string Href { get; set; } = "/";
    [Parameter] public string Icon { get; set; } = "bi-circle";
    [Parameter] public string Text { get; set; } = "";
}
