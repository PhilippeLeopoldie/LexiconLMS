<div class="lms-listcard">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <div class="lms-listcard__header">
            <h3>@Title</h3>
            <div>@HeaderActions</div>
        </div>
    }

    <ul class="lms-listcard__list">
        @if (Items is not null)
        {
            @foreach (var item in Items)
            {
                <li class="lms-listcard__item">
                    <div class="lms-listcard__left">
                        @if (item.Icon is not null)
                        {
                            <span class="lms-avatar">@item.Icon</span>
                        }
                        <div class="lms-listcard__text">
                            <div class="lms-listcard__title">@item.Title</div>
                            @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                            {
                                <div class="lms-listcard__subtitle">@item.Subtitle</div>
                            }
                        </div>
                    </div>

                    <div class="lms-listcard__right">
                        @item.Meta
                        @item.Actions
                    </div>
                </li>
            }
        }
        else
        {
            @ChildContent
        }
    </ul>
</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? HeaderActions { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public IEnumerable<ListCardItem>? Items { get; set; }

    public class ListCardItem
    {
        public RenderFragment? Icon { get; set; }
        public string Title { get; set; } = "";
        public string? Subtitle { get; set; }
        public RenderFragment? Meta { get; set; }
        public RenderFragment? Actions { get; set; }
    }
}
