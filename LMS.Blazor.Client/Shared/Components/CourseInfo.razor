@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Domain.Models.Entities
@using LMS.Blazor.Client.Services
@using LMS.Shared.DTOs.CourseDtos

<div class="lms-section">
    <div class="lms-section__header">
        <div class="lms-section__title">
            <h3>@course?.Name</h3> @FormatDateRange(course?.Starts, course?.Ends)
        </div>
    </div>
    <div class="lms-section__body">
        <FaderBox text="@course?.Description" />
        <StudentList Title="Students in Your course" Students="@course?.Students" />
    </div>
</div>

@code {
    [Parameter] public int courseId { get; set; }
    [Inject] private IApiService apiService { get; set; } = default!;
    public CourseDto? course { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        //var user = authContext.
        course = await apiService.CallApiAsync<CourseDto>($"api/courses/{courseId}"); //?includeModules=true&includeActivities=false");
    }

    private string FormatDateRange(DateTime? start, DateTime? end)
    {
        if (start == null && end == null)
            return "";

        if (end == null)
            return start.Value.ToString("d MMM, yyyy -");
        else if (start == null)
            return end.Value.ToString("- d MMM, yyyy");

        bool isSameStartAndEndYear = start.Value.Year == end.Value.Year;
        return start.Value.ToString("d MMM" + (isSameStartAndEndYear ? "" : ", YYYY")) + end.Value.ToString(" - d MMM, yyyy");
    }
}
