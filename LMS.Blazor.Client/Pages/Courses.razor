@using LMS.Blazor.Client.Services
@using LMS.Blazor.Client.Shared.Components
@using LMS.Shared.DTOs.CourseDtos
@using LMS.Shared.Helpers
@using Microsoft.AspNetCore.Authorization

@page "/courses"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Roles = "Teacher")]

<PageTitle>Kurser</PageTitle>

<h3>Kurser</h3>
@if (courses == null)
{
    <p>Laddar kurser...</p>
}
else
{
    <AuthorizeView Context="authContext" Roles="Teacher">
        <Authorized>
            <div class="container-fluid">
                <div class="row">
                    <div class="col p-4">
                        <div class="row g-3">
                            <div class="col-12">
                                <Section Title="Kurser"
                                         Icon="@(builder => builder.AddMarkupContent(0, "<i class='bi bi-journals'></i>"))"
                                         HeaderActions="@(builder => builder.AddMarkupContent(0, "<a href='/courses/createcourse' class='btn btn-primary'>+ Skapa kurs</a>"))">
                                    <ul class="list-unstyled mb-0">
                                        @if (courses.Count == 0)
                                        {
                                            <p>Inga kurser tillgängliga. Skapa en ny kurs för att komma igång!</p>
                                        }
                                        else
                                        {
                                            @foreach (var course in courses) 
                                            {
                                                var moduleCount = course.Modules?.Count() ?? 0;
                                                var studentCount = course.Students?.Count() ?? 0;

                                                <NavLink class="nav-link mt-1" href=@($"/courses/{course.Id}/modules") Match=@NavLinkMatch.All>
                                                    <CourseRow Title="@course.Name" Sub="@($"{studentCount} studenter • {moduleCount} moduler")" MenuContent="@CourseMenu(course)">
                                                        <Icon><i class="bi bi-journal-code"></i></Icon>
                                                        <Suffix><DateBadge Start="@course.Starts" End="@course.Ends"/></Suffix>
                                                    </CourseRow>
                                                </NavLink>
                                            }
                                        }
                                    </ul>
                                </Section>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </Authorized>
    </AuthorizeView>
}

@code {
    private RenderFragment CourseMenu(CourseDto course) => __builder =>
        {
            <div class="dropstart dropup flex-shrink-0" style="width:5%">
                <button class="btn btn-link w-100" data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots-vertical"></i>
                </button>
                <ul class="manage-actions dropdown-menu" data-popper-placement="left-start">
                    <!-- Edit -->
                    <button class="dropdown-item btn btn-link" @onclick="() => Edit(course)">
                        <i class="bi bi-pencil-square"></i> Redigera
                    </button>
                    
                </ul>
            </div>
        };

    [Inject] private IApiService _apiService { get; set; } = default!;
    [Inject] private NavigationManager _navigationManager { get; set; } = default!;
    //[Inject] private CourseStateService _courseState { get; set; } = default!;

    private List<CourseDto>? courses;

    protected override async Task OnInitializedAsync()
    {
        var requestParams = new RequestParams() { OrderBy = OrderByParams.DateDesc, PageSize = 10 };
        var queryString = QueryStringHelper.ObjectToQueryString(requestParams);

        var response = await _apiService.CallApiAsync<IEnumerable<CourseDto>>($"api/courses/{queryString}&includeModules=true&includeActivities=true");
        courses = response?.ToList();
    }

    private void Edit(CourseDto course)
    {
        //_courseState.Course = course;
        _navigationManager.NavigateTo($"/courses/editcourse/{course.Id}");
    }

}
