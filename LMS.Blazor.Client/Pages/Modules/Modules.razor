@using LMS.Shared.DTOs.ModuleDtos
@using LMS.Blazor.Client.Shared.Components

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
<h3>Modules</h3>
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        Fel: @errorMessage
    </div>
}
else if (isLoading)
{
    <p>Laddar moduler...</p>
}
else
{
<div class="container-fluid">
                <div class="row">
                    <div class="col p-4">
                        <div class="row g-3">
                            <div class="col-12">
                                <Section Title="Moduler"
                                         Icon="@(builder => builder.AddMarkupContent(0, "<i class='bi bi-journal-code'></i>"))" 
                                        HeaderActions="@(builder => builder.AddMarkupContent(0, "<a href='/' class='btn btn-primary'>+ Skapa modul</a>"))">
                                    <ul class="list-unstyled mb-0">
                                        @if (modules?.Count == 0)
                                        {
                                            <p>Denna kurs har inga moduler...</p>
                                        }
                                        else
                                        {
                                            @foreach (var module in modules)
                                            {
                                                var activityCount = module.Activities?.Count() ?? 0;
                                                <NavLink class="nav-link" href="@($"/courses/{courseId}/modules/{module.Id}/activities")" Match="@NavLinkMatch.All">
                                                    <CourseRow Title="@module.Name" Sub="@($"{activityCount} Aktiviteter")">
                                                        <Icon><i class="bi bi-cpu"></i></Icon>
                                                        <Suffix><Badge Color="info">Aktiv</Badge></Suffix>
                                                    </CourseRow>
                                                </NavLink>
                                            }
                                        }

                                    </ul>
                                </Section>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
}
@code {


    private List<ModuleDto>? modules { get; set; } = [];
    [Parameter]
    public int courseId { get; set; }

    [Inject]
    private IApiService _apiService { get; set; } = default!;

    private string? errorMessage;
    private bool isLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        var requestParams = new ModuleRequestParams()
        {
            OrderBy = OrderByParams.DateAsc,
            PageSize = 100,
            IncludeActivities = true
        };
        var queryString = ObjectToQueryString(requestParams);

        isLoading = true;
        try
        {
            var response = await _apiService.CallApiAsync<IEnumerable<ModuleDto>>($"api/courses/{courseId}/Module?{queryString}");
            modules = response?.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }

    }
    //convert object to query string, ex: OrderBy=DateAsc&PageSize=100&IncludeActivities=True
    public string ObjectToQueryString(object obj)
    {
        var properties = from property in obj.GetType().GetProperties()
                         where property.GetValue(obj, null) != null
                         select property.Name + "=" + HttpUtility.UrlEncode(property.GetValue(obj, null)!.ToString());

        return string.Join("&", properties.ToArray());
    }
}
