@using LMS.Blazor.Client.Services
@using LMS.Blazor.Client.Shared.Components
@using LMS.Shared.DTOs.ModuleDtos
@using Microsoft.AspNetCore.Authorization

@page "/courses/{courseId:int}/modules"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Moduler</PageTitle>



<AuthorizeView Context="authContext">
    <Section Title="Moduler"
             Icon="@(builder => builder.AddMarkupContent(0, "<i class='bi bi-journal-code'></i>"))"
             HeaderActions="@(authContext.User.IsInRole("Teacher")
                                           ? (builder => builder.AddMarkupContent(0, $"<a href='/courses/{courseId}/modules/create' class='btn btn-primary'>+ Skapa modul</a>"))
                              : null)">
        <ModulesComponent courseId="@courseId" />
    </Section>
</AuthorizeView>


@code {
    [Parameter]
    public int courseId { get; set; }
    
}
