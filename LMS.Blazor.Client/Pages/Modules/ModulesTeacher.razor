@using LMS.Blazor.Client.Services
@using LMS.Blazor.Client.Shared.Components
@using LMS.Shared.DTOs.ModuleDtos
@using Microsoft.AspNetCore.Authorization

@page "/teacher/courses/{courseId:int}/modules"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Roles ="Teacher")]

<PageTitle>Moduler</PageTitle>

<h1>Lärare</h1>

    <AuthorizeView Context="authContext" Roles="Teacher">
        <Authorized>
            <Modules courseId=@courseId/>
        </Authorized>
    </AuthorizeView>

@code {
    [Parameter]
    public int courseId { get; set; }//temporary value for testing
    
}
