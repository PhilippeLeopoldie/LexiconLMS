@using LMS.Blazor.Client.Services
@using LMS.Blazor.Client.Shared.Components
@using LMS.Shared.DTOs.ModuleDtos
@using Microsoft.AspNetCore.Authorization

@page "/modules-student"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Roles ="Student")]

<PageTitle>Moduler</PageTitle>

<h1>Student</h1>
@if (modules == null)
{
    <p>Laddar moduler...</p>
}
else
{
    <AuthorizeView Context="authContext" Roles="Student">
        <Authorized>
            <Modules modules=@modules />
        </Authorized>
    </AuthorizeView>
}

@code {
    [Parameter]
    public int courseId { get; set; } = 16;//temporary value for testing
    [Parameter]
    public bool includeActivities { get; set; }  = true;

    [Inject]
    private IApiService _apiService { get; set; } = default!;

    private List<ModuleDto>? modules;
    
    

    protected override async Task OnInitializedAsync()
    {
        var response = await _apiService.CallApiAsync<IEnumerable<ModuleDto>>($"api/courses/{courseId}:int/Module?IncludeActivities={includeActivities}");
        modules = response?.ToList();
    }
}
