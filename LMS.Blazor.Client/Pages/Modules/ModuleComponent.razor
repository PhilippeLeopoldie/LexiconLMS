@using LMS.Shared.DTOs.ModuleDtos
@using LMS.Blazor.Client.Shared.Components
@using LMS.Shared.Helpers

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        Fel: @errorMessage
    </div>
}
else if (isLoading)
{
    <p>Laddar moduler...</p>
}
else
{
<div class="container-fluid">
                <div class="row">
                    <div class="col p-4">
                        <div class="row g-3">
                            <div class="col-12">
                                <Section>
                                    <ul class="list-unstyled mb-0">
                                        @if (modules?.Count == 0)
                                        {
                                            <p>Denna kurs har inga moduler...</p>
                                        }
                                        else
                                        {
                                            @foreach (var module in modules!)
                                            {
                                                var activityCount = module.Activities?.Count() ?? 0;
                                                <div class="d-flex w-100">
                                                    <NavLink class="nav-link flex-grow-1 mt-1" href="@($"/courses/{CourseId}/modules/{module.Id}/activities")" Match="@NavLinkMatch.All">
                                                        <CourseRow 
                                                            Title="@($"{module.Name}   ({module.StartsAt:d}  -  {module.EndsAt:d})")" 
                                                            Sub="@($"{activityCount} Aktiviteter")"
                                                            MenuContent="@ModuleMenu(module)"
                                                        >
                                                            <Icon><i class="bi bi-cpu"></i></Icon>
                                                            <Suffix><DateBadge Start="@module.StartsAt" End="@module.EndsAt" /></Suffix>
                                                        </CourseRow>
                                                    </NavLink>
                                        </div>
                                    }
                                }
                            </ul>
                        </Section>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@code {
    private RenderFragment ModuleMenu(ModuleDto module) => __builder =>
    {
        <div class="dropstart dropup flex-shrink-0" style="width:5%">
            <button class="btn btn-link w-100" data-bs-toggle="dropdown">
                <i class="bi bi-three-dots-vertical"></i>
            </button>
            <ul class="manage-actions dropdown-menu" data-popper-placement="left-start">
                <!-- Edit -->
                <button class="dropdown-item btn btn-link" @onclick="() => Edit(module)">
                    <i class="bi bi-pencil-square"></i> Redigera
                </button>

                <!-- Delete -->
                <button class="dropdown-item btn btn-link text-danger" @onclick="() => Delete()">
                    <i class="bi bi-trash"></i> Ta bort
                </button>
            </ul>
        </div>
    };

    private List<ModuleDto>? modules { get; set; } = [];
    [Parameter]
    public int CourseId { get; set; }

    [Inject] private IApiService _apiService { get; set; } = default!;
    [Inject] private NavigationManager _navigationManager { get; set; } = default!;
    [Inject] private ModuleStateService _moduleState { get; set; } = default!;

    private string? errorMessage;
    private bool isLoading { get; set; } = true;

    private void Edit(ModuleDto module)
    {
        _moduleState.Module = module;
        _navigationManager.NavigateTo($"/courses/{CourseId}/module/{module.Id}/edit");
    }

    private void Delete()
    {
        _navigationManager.NavigateTo($"/courses/{CourseId}/modules");// temporary route
    }



    protected override async Task OnInitializedAsync()
    {
        var requestParams = new ModuleRequestParams()
        {
            OrderBy = OrderByParams.DateAsc,
            PageSize = 100,
            IncludeActivities = true
        };
        var queryString = QueryStringHelper.ObjectToQueryString(requestParams);

        isLoading = true;
        try
        {
            var response = await _apiService.CallApiAsync<IEnumerable<ModuleDto>>($"api/courses/{CourseId}/Module?{queryString}");
            modules = response?.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }

    }    
}
