@page "/users/edit/{userId}"
@attribute [Authorize(Roles = "Teacher")]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject IApiService _apiService
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _auth

<PageTitle>Redigera användare</PageTitle>

@if (isLoading)
{
    <Spinner EntityName="användare" />
}
else
{
    <div class="col-xl-8">
        <Section Title="Redigera användare">
            <HeaderActions>
                <button class="btn btn-secondary" type="button" @onclick="NavigateBack">Avbryt</button>
            </HeaderActions>
            <ChildContent>
                <EditForm Model="user" OnValidSubmit="HandleSubmit" FormName="UserForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="row">
                        <div class="mb-3 col-12 col-lg-6">
                            <label class="form-label">Fullständigt namn</label>
                            <InputText class="form-control" @bind-Value="user.FullName" disabled="true" />
                        </div>

                        <div class="mb-3 col-12 col-lg-6">
                            <label class="form-label">Användarnamn</label>
                            <InputText class="form-control" @bind-Value="user.UserName" disabled="true" />
                        </div>

                        <div class="mb-3 col-12">
                            <label class="form-label">Email</label>
                            <InputText class="form-control" @bind-Value="user.Email" disabled="true" />
                            <ValidationMessage For="@(() => user.Email)" />
                        </div>

                        <div class="mb-3 col-12 col-lg-6">
                            <label class="form-label">Förnamn</label>
                            <InputText class="form-control" @bind-Value="user.FirstName" />
                            <ValidationMessage For="() => user.FirstName" />
                        </div>

                        <div class="mb-3 col-12 col-lg-6">
                            <label class="form-label">Efternamn</label>
                            <InputText class="form-control" @bind-Value="user.LastName" />
                            <ValidationMessage For="() => user.LastName" />
                        </div>

                        <div class="mb-3 col-12 col-lg-6">
                            <label class="form-label">Telefonnummer</label>
                            <InputText class="form-control" @bind-Value="user.PhoneNumber" />
                            <ValidationMessage For="() => user.PhoneNumber" />
                        </div>

                        <div class="mb-3 col-12 col-lg-6">
                            <label class="form-label">Roll</label>
                            <InputSelect class="form-select" @bind-Value="user.Role">
                                <option value="Student">Student</option>
                                <option value="Teacher">Teacher</option>
                            </InputSelect>
                        </div>

                        <div class="row">
                            <div class="col-12 mb-3">
                                <label class="form-label" for="course">Kurs</label>
                                <InputSelect @bind-Value="user.CourseId" class="form-select">
                                    <option value="">Välj en kurs...</option>
                                    @foreach (var course in courses)
                                    {
                                        <option value="@course.Id">@course.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => user.CourseId" class="text-danger" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger">@errorMessage</div>
                        }

                        <div class="d-flex">
                            <button class="btn btn-success" type="submit">Spara</button>
                        </div>
                    </div>
                </EditForm>
            </ChildContent>
        </Section>
    </div>
}

