@page "/users/edit/{userId}"
@attribute [Authorize]

@inject IApiService _apiService
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _auth

<PageTitle>@(IsEditMode ? "Redigera användare" : "Skapa användare")</PageTitle>

@if (isLoading)
{
    <Spinner EntityName="användare" />
}
else
{
    <h3>@(IsEditMode ? "Redigera användare" : "Skapa användare")</h3>
    <hr />

    <EditForm Model="user" OnValidSubmit="HandleSubmit" FormName="UserForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Användarnamn</label>
            <InputText class="form-control" @bind-Value="user.UserName" />
            <ValidationMessage For="@(() => user.UserName)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Förnamn (valfritt)</label>
            <InputText class="form-control" @bind-Value="user.FirstName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Efternamn (valfritt)</label>
            <InputText class="form-control" @bind-Value="user.LastName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Telefon (valfritt)</label>
            <InputText class="form-control" @bind-Value="user.PhoneNumber" />
        </div>

        @if (CanEditEmail)
        {
            <div class="mb-3">
                <label class="form-label">E-post</label>
                <InputText class="form-control" @bind-Value="user.Email" />
                <ValidationMessage For="@(() => user.Email)" />
            </div>
        }
        else if (IsEditMode)
        {
            <div class="mb-3">
                <label class="form-label">E-post</label>
                <InputText class="form-control" @bind-value="user.Email" Disabled />
            </div>
        }

        @if (!IsEditMode)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i>
                <strong>Lösenord:</strong> Användaren kommer att få ett e-postmeddelande med en länk för att skapa sitt eget lösenord.
            </div>
        }

        @if (IsTeacher)
        {
            <div class="mb-3">
                <label class="form-label">Roll (valfritt)</label>
                <InputSelect class="form-select" @bind-Value="user.Role">
                    <option value="Student">Student</option>
                    <option value="Teacher">Teacher</option>
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Kurs ID (valfritt)</label>
                <InputNumber class="form-control" @bind-Value="user.CourseId" />
                <small class="form-text text-muted">Lämna tomt för lärare eller om studenten inte ska kopplas till en kurs ännu.</small>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div class="d-flex gap-2">
            <button class="btn btn-primary" type="submit">@(IsEditMode ? "Spara" : "Skapa")</button>
            <button class="btn btn-secondary" type="button" @onclick="NavigateBack">Avbryt</button>
        </div>
    </EditForm>
}


