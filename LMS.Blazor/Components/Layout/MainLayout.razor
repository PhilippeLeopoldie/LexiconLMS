@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject ThemeService ThemeService

<CascadingAuthenticationState>
    <div class="page">
        <AuthorizeView>
            <Authorized>
                <TopBar />
                <div class="row">
                    <Sidebar />
                    <main>
                        <article class="content p-4 mb-5">
                            @Body
                        </article>
                    </main>
                </div>
            </Authorized>
            <NotAuthorized>
                <TopBar />
                <main class="d-flex flex-nowrap">
                    <article class="content px-4">
                        @if (NavigationManager.ToBaseRelativePath(NavigationManager.Uri).StartsWith("Account/CompleteRegistration"))
                        {
                            @Body
                        }
                        else
                        {
                            <Login />
                        }
                    </article>
                </main>
            </NotAuthorized>
        </AuthorizeView>
        <Footer />
    </div>
</CascadingAuthenticationState>
@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeThemeAsync();
        }
        else
        {
            await ThemeService.ApplyThemeAsync();
        }
    }
}
