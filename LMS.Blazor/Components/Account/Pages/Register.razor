@page "/Account/CompleteRegistration"
@rendermode InteractiveServer 

@inject ILogger<Login> logger
@inject IApiService apiService
@inject NavigationManager navigationManager
@inject UserManager<ApplicationUser> userManager

<PageTitle>Slutför registrering</PageTitle>
<Section Title="Slutför registrering" >
<h2>Välkommen! Slutför din registrering genom att ange ditt lösenord.</h2>

<Section>
        <div class="row">
            <div class="col-md-4">
        <StatusMessage Message="@errorMessage" />
        <EditForm Model="Input" asp-route-returnUrl="@ReturnUrl" method="post" OnValidSubmit="CompleteRegistration" FormName="register">
            <DataAnnotationsValidator />
            <h2>Slutför din registrering</h2>
            <hr />
            <ValidationSummary class="text-danger" role="alert" />
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" disabled="true" />
                <label for="email">E-post</label>
                <ValidationMessage For="() => Input.Email" class="text-danger" />
            </div>
            @if (!string.IsNullOrEmpty(InvitedUserName))
            {
                <div class="form-floating mb-3">
                    <input type="text" value="@InvitedUserName" class="form-control" disabled />
                    <label for="name">Namn</label>
                </div>
            }
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.FirstName" class="form-control" autocomplete="given-name" placeholder="Förnamn" />
                <label for="firstName">Förnamn</label>
                <ValidationMessage For="() => Input.FirstName" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.LastName" class="form-control" autocomplete="family-name" placeholder="Efternamn" />
                <label for="lastName">Efternamn</label>
                <ValidationMessage For="() => Input.LastName" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.PhoneNumber" class="form-control" autocomplete="tel" placeholder="Telefonnummer" />
                <label for="phoneNumber">Telefonnummer</label>
                <ValidationMessage For="() => Input.PhoneNumber" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText type="password" @bind-Value="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                <label for="password">Lösenord</label>
                <ValidationMessage For="() => Input.Password" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText type="password" @bind-Value="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="lösenord" />
                <label for="confirm-password">Bekräfta lösenord</label>
                <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">Slutför registrering</button>
        </EditForm>
    </div>
</div>
</Section>
</Section>

@code {
    private string? errorMessage;
    private string? InvitedUserName;
     private ApplicationUser? invitedUser;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Email))
        {
            Input.Email = Email;

            invitedUser = await userManager.FindByEmailAsync(Email);
            if (invitedUser != null)
            {
                InvitedUserName = invitedUser.UserName;

                Input.FirstName = invitedUser.FirstName ?? "";
                Input.LastName = invitedUser.LastName ?? "";
                Input.PhoneNumber = invitedUser.PhoneNumber ?? "";
                Input.UserName = invitedUser.UserName ?? "";

                if (await userManager.HasPasswordAsync(invitedUser))
                {
                    navigationManager.NavigateTo("/Account/Login", forceLoad: true);
                    logger.LogDebug("User already has password");
                    return;
                }
            }
            else
            {
                errorMessage = "Ogiltig inbjudan. Användaren hittades inte.";
                return;
            }
        }
        else
        {
            errorMessage = "Ingen e-postadress angiven. Denna sida är endast för slutförande av inbjudningar.";
        }
    }

    public async Task CompleteRegistration(EditContext editContext)
    {
        if (invitedUser == null)
        {
            errorMessage = "Ogiltig inbjudan.";
            return;
        }

        try
        {
            var registrationDto = new UserRegistrationDto
            {
                Email = Input.Email,
                UserName = Input.UserName,
                Password = Input.Password,
                FirstName = Input.FirstName,
                LastName = Input.LastName,
                PhoneNumber = Input.PhoneNumber
            };
            await apiService.PostAsync("api/auth/register", registrationDto);

            navigationManager.NavigateTo("/Account/Login", forceLoad: true);
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Ett fel uppstod vid registrering.";
            logger.LogWarning(ex.Message);
        }
        catch (Exception ex)
        {
            errorMessage ="Ett oväntat fel uppstod. Försök igen.";
            logger.LogWarning(ex.Message);
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        [Display(Name = "E-post")]
        public string Email { get; set; } = "";

        [Required]
        [Display(Name = "Användarnamn")]
        public string UserName { get; set; } = "";

        [Required]
        [Display(Name = "Förnamn")]
        public string FirstName { get; set; } = "";

        [Required]
        [Display(Name = "Efternamn")]
        public string LastName { get; set; } = "";

        [Display(Name = "Telefonnummer")]
        public string PhoneNumber { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        [Display(Name = "Lösenord")]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Bekräfta lösenord")]
        [Compare("Password", ErrorMessage = "Lösenorden stämmer inte överens.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
