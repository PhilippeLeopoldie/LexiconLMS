<StatusMessage Message="@StatusMessage" />
<h3>Återställningskoder</h3>
<div class="alert alert-warning" role="alert">
    <p>
        <strong>Lagra dessa koder på ett säkert ställe.</strong>
    </p>
    <p>
        On du förlorar din enhet och inte har återställningskoderna kommer du att förlora åtkomsten till ditt konto.
    </p>
</div>
<div class="row">
    <div class="col-md-12">
        @foreach (var recoveryCode in RecoveryCodes)
        {
            <div>
                <code class="recovery-code">@recoveryCode</code>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string[] RecoveryCodes { get; set; } = [];

    [Parameter]
    public string? StatusMessage { get; set; }
}
